{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/suzuki-shunsuke/ghtkn-go-sdk/ghtkn/config/config",
  "$ref": "#/$defs/Config",
  "$defs": {
    "App": {
      "properties": {
        "name": {
          "type": "string"
        },
        "client_id": {
          "type": "string"
        },
        "git_owner": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "client_id"
      ]
    },
    "Config": {
      "properties": {
        "apps": {
          "items": {
            "$ref": "#/$defs/App"
          },
          "type": "array"
        },
        "skip_account_picker": {
          "type": "boolean"
        },
        "open_browser": {
          "$ref": "#/$defs/OpenBrowser"
        },
        "min_expiration": {
          "type": "string"
        },
        "device_flow": {
          "$ref": "#/$defs/DeviceFlow"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "apps"
      ]
    },
    "DeviceFlow": {
      "properties": {
        "enable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "OpenBrowser": {
      "properties": {
        "enable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  }
}
